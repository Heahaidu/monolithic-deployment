[
    {
      "name": "backend",
      "image": "${account_id}.dkr.ecr.${aws_region}.amazonaws.com/${project_name}/backend:latest",
      "cpu": 0,
      "portMappings": [
        {
          "containerPort": ${container_port},
          "hostPort": ${host_port},
          "protocol": "tcp",
          "appProtocol": "http"
        }
      ],
      "essential": true,
      "environment": [],
      "mountPoints": [],
      "volumesFrom": [],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/${project_name}/backend",
          "awslogs-create-group": "true",
          "awslogs-region": "${aws_region}",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "wget -qO- ${health_check_url} || exit 1"
        ],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 120
      }
    }
]